{
    "manifest_version": 3,
    "name": "Claude Sidebar Saver",
    "version": "1.0.0",
    "description": "Capture and save Claude Chrome extension sidebar conversations to local storage, Markdown, or Notion",
    "permissions": [
          "webRequest",
          "storage",
          "downloads",
          "activeTab",
          "tabs",
          "scripting"
    ],
    "host_permissions": [
          "https://api.anthropic.com/*",
          "https://*.anthropic.com/*",
          "https://*.claude.ai/*",
          "https://api.notion.com/*"
    ],
    "background": {
          "service_worker": "background.js"
    },
    "action": {
          "default_popup": "popup.html",
          "default_title": "Claude Sidebar Saver"
    },
    "options_page": "options.html"
}
