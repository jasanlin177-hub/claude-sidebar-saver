{
          "manifest_version": 3,
          "name": "Claude Sidebar Saver",
          "version": "1.2.1",
          "description": "Capture and save Claude conversations to local storage, Markdown, or Notion",
          "permissions": ["storage", "downloads", "notifications", "webRequest"],
          "host_permissions": [
                      "*://api.anthropic.com/*",
                      "*://claude.ai/*",
                      "*://*.anthropic.com/*",
                      "*://*.claude.ai/*",
                      "https://api.notion.com/*"
          ],
          "background": { "service_worker": "background.js" },
          "content_scripts": [
                      {
                                    "matches": ["*://claude.ai/*", "*://*.claude.ai/*"],
                                    "js": ["content-script.js"],
                                    "run_at": "document_start",
                                    "world": "MAIN"
                      },
                      {
                                    "matches": ["*://claude.ai/*", "*://*.claude.ai/*"],
                                    "js": ["content-bridge.js"],
                                    "run_at": "document_start",
                                    "world": "ISOLATED"
                      }
          ],
          "action": {
                      "default_popup": "popup.html"
          },
          "options_page": "options.html"
}
