{
      "manifest_version": 3,
      "name": "Claude Sidebar Saver",
      "version": "1.1.0",
      "description": "Capture and save Claude sidebar conversations to local storage, Markdown, or Notion",
      "permissions": ["debugger", "storage", "downloads", "notifications", "tabs"],
      "host_permissions": [
              "*://api.anthropic.com/*",
              "*://claude.ai/*",
              "*://*.anthropic.com/*",
              "*://*.claude.ai/*",
              "https://api.notion.com/*"
      ],
      "background": { "service_worker": "background.js" },
      "action": {
              "default_popup": "popup.html"
      },
      "options_page": "options.html"
}
